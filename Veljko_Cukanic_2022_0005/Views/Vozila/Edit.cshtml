@model AutoService.Application.DTOs.VoziloDto

@{
    ViewData["Title"] = "Izmena vozila";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header">
            <h2>Izmena vozila</h2>
        </div>

        <div class="card-body">
            <form asp-action="Edit" method="post">
                <input asp-for="VoziloId" type="hidden" />

                <div asp-validation-summary="ModelOnly"
                     class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Marka" class="form-label"></label>
                    <input asp-for="Marka" class="form-control" />
                    <span asp-validation-for="Marka"
                          class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Model" class="form-label"></label>
                    <input asp-for="Model" class="form-control" />
                    <span asp-validation-for="Model"
                          class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="GodinaProizvodnje"
                           class="form-label"></label>
                    <input asp-for="GodinaProizvodnje"
                           class="form-control" />
                    <span asp-validation-for="GodinaProizvodnje"
                          class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Registracija"
                           class="form-label"></label>
                    <input asp-for="Registracija"
                           class="form-control" />
                    <span asp-validation-for="Registracija"
                          class="text-danger"></span>
                </div>

                @if (ViewBag.IsAdmin == true)
                {
                    <div class="mb-3">
                        <label asp-for="VlasnikId"
                               class="form-label"></label>

                        <select asp-for="VlasnikId"
                                asp-items="ViewBag.Vlasnici"
                                class="form-select">
                            <option value="">Izaberite vlasnika</option>
                        </select>

                        <span asp-validation-for="VlasnikId"
                              class="text-danger"></span>
                    </div>
                }
                else
                {
                    <input asp-for="VlasnikId" type="hidden" />
                }

                <button type="submit" class="btn btn-primary">
                    Sačuvaj izmene
                </button>

                <a asp-action="Index" class="btn btn-secondary">
                    Nazad
                </a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

