@model AutoService.Domain.Models.Vozilo

@{
    ViewData["Title"] = "Brisanje vozila";
}

<div class="container mt-4">
    <div class="card border-danger shadow">
        <div class="card-header bg-danger text-white">
            <h2>Brisanje vozila</h2>
        </div>

        <div class="card-body">
            <p>
                Da li ste sigurni da želite da obrišete vozilo?
            </p>

            <dl class="row">
                <dt class="col-sm-3">Vozilo</dt>
                <dd class="col-sm-9">
                    @Model.Marka @Model.Model
                </dd>

                <dt class="col-sm-3">Registracija</dt>
                <dd class="col-sm-9">
                    @Model.Registracija
                </dd>

                <dt class="col-sm-3">Vlasnik</dt>
                <dd class="col-sm-9">
                    @Model.Korisnik.Ime @Model.Korisnik.Prezime
                </dd>

                <dt class="col-sm-3">Broj termina</dt>
                <dd class="col-sm-9">
                    @Model.Termini.Count
                </dd>
            </dl>

            @if (Model.Termini.Any())
            {
                <div class="alert alert-warning">
                    Vozilo ima evidentirane termine i ne može biti obrisano.
                </div>
            }

            <form asp-action="DeleteConfirmed"
                  asp-route-id="@Model.VoziloId"
                  method="post">

                <button type="submit"
                        class="btn btn-danger">
                    Potvrdi brisanje
                </button>

                <a asp-action="Index"
                       class="btn btn-secondary">
                    Odustani
                </a>
            </form>
        </div>
    </div>
</div>