@model AutoService.Domain.Models.Serviser

@{
    ViewData["Title"] = "Brisanje servisera";
}

<div class="container mt-4">
    <div class="card border-danger shadow">
        <div class="card-header bg-danger text-white">
            <h2>Brisanje servisera</h2>
        </div>

        <div class="card-body">
            <p>
                Da li ste sigurni da želite da obrišete servisera?
            </p>

            <dl class="row">
                <dt class="col-sm-3">Ime i prezime</dt>
                <dd class="col-sm-9">
                    @Model.Ime @Model.Prezime
                </dd>

                <dt class="col-sm-3">Specijalizacija</dt>
                <dd class="col-sm-9">
                    @Model.Specijalizacija
                </dd>

                <dt class="col-sm-3">Broj termina</dt>
                <dd class="col-sm-9">
                    @Model.Termini.Count
                </dd>
            </dl>

            @if (Model.Termini.Any())
            {
                <div class="alert alert-warning">
                    Serviser ima termine i biće deaktiviran umesto obrisan.
                </div>
            }

            <form asp-action="DeleteConfirmed"
                  asp-route-id="@Model.ServiserId"
                  method="post">

                <button type="submit"
                        class="btn btn-danger">
                    Potvrdi
                </button>

                <a asp-action="Index"
                       class="btn btn-secondary">
                    Odustani
                </a>
            </form>
        </div>
    </div>
</div>
