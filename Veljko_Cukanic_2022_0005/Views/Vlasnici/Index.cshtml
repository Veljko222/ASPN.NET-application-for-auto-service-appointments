@model IEnumerable<AutoService.Domain.Models.Vlasnik>

@{
    ViewData["Title"] = "Vlasnici";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Vlasnici</h2>

        <a asp-action="Create" class="btn btn-primary">
            Dodaj vlasnika
        </a>
    </div>

    @if (TempData["Uspeh"] != null)
    {
        <div class="alert alert-success">
            @TempData["Uspeh"]
        </div>
    }

    @if (TempData["Greska"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Greska"]
        </div>
    }

    <form method="get" class="row g-2 mb-3">
        <div class="col-md-8">
            <input type="text"
                   name="pretraga"
                   value="@ViewBag.Pretraga"
                   class="form-control"
                   placeholder="Pretraži po imenu, prezimenu, emailu ili telefonu" />
        </div>

        <div class="col-md-4">
            <button type="submit" class="btn btn-outline-primary">
                Pretraži
            </button>

            <a asp-action="Index" class="btn btn-outline-secondary">
                Resetuj
            </a>
        </div>
    </form>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            Nema vlasnika.
        </div>
    }
    else
    {
        <table class="table table-striped table-bordered">
            <thead>
                <tr>
                    <th>Ime</th>
                    <th>Prezime</th>
                    <th>Email</th>
                    <th>Telefon</th>
                    <th>Akcije</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var vlasnik in Model)
                {
                    <tr>
                        <td>@vlasnik.Ime</td>
                        <td>@vlasnik.Prezime</td>
                        <td>@vlasnik.Email</td>
                        <td>@vlasnik.Telefon</td>
                        <td>
                            <a asp-action="Details"
                                   asp-route-id="@vlasnik.VlasnikId"
                                   class="btn btn-info btn-sm">
                                Detalji
                            </a>

                            <a asp-action="Edit"
                                   asp-route-id="@vlasnik.VlasnikId"
                                   class="btn btn-warning btn-sm">
                                Izmeni
                            </a>

                            <a asp-action="Delete"
                                   asp-route-id="@vlasnik.VlasnikId"
                                   class="btn btn-danger btn-sm">
                                Obriši
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
